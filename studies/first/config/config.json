{
  "params": "$path:params.json",
  "radial_build": {
    "run_mode": "read",
    "input_in_dat_path": "$path_expand:../data/PROCESS/st_regression.IN.DAT",
    "read_dir": "$path_expand:../data/PROCESS/run_dir",
    "run_dir": "$path_expand:../data/PROCESS/run_dir",
    "plot": false
  },
  "reference_fbe": {
    "plot_setup": false,
    "plot": true,
    "coilset": {
      "coil_discretisation": 0.1
    },
    "grid": {
      "nx": 100,
      "nz": 200
    },
    "solver": {
      "plot": true,
      "iter_err_max": 1e-2
    },
    "optimisation": {
      "gamma": 1e-8,
      "constraint": {
        "n_points": 5
      }
    }
  },
  "plasma": {},
  "tf_coils": {
    "run_mode": "run",
    "file_path": "$path_expand:../data/TF/TFCoilDesign.json",
    "plot": true,
    "material": {
      "Winding Pack": "Toroidal_Field_Coil_2015",
      "Casing": "Toroidal_Field_Coil_2015",
      "Insulation": "Toroidal_Field_Coil_2015"
    },
    "problem_class": "bluemira.builders.tf_coils::RippleConstrainedLengthGOP",
    "problem_settings": {
      "ripple_selector": {
        "cls": "bluemira.builders.tf_coils::EquispacedSelector",
        "args": { "n_rip_points": 10 }
      },
      "n_koz_points": 50,
      "nx": 1,
      "ny": 1
    },
    "optimisation_settings": {
      "algorithm_name": "SLSQP",
      "conditions": { "max_eval": 200, "ftol_rel": 1e-6 }
    }
  }
}
