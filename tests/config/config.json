{
  "params": "$path:params.json",
  "reference_fbe": {
    "plot_setup": true,
    "plot": true,
    "coilset": {
      "coil_discretisation": 0.1
    },
    "grid": {
      "nx": 100,
      "nz": 100
    },
    "solver": {
      "plot": true,
      "iter_err_max": 1e-2
    },
    "optimisation": {
      "gamma": 1e-8,
      "constraint": {
        "n_points": 5
      }
    }
  }
}
